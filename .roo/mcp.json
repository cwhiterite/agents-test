{
	"mcpServers": {
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp"
			],
			"env": {
				"DEFAULT_MINIMUM_TOKENS": ""
			},
			"alwaysAllow": [
				"resolve-library-id"
			]
		},
		"sequentialthinking": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-sequential-thinking"
			]
		},
		"superpowers": {
			"command": "node",
			"args": [
				"C:/Users/cwhite/vscode/superpowers-mcp/build/index.js"
			],
			"alwaysAllow": [
				"list_skills"
			]
		}
	}
}